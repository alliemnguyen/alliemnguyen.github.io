  journal = {Environmental Science \& Technology},
  publisher = {American Chemical Society},
  issn = {0013-936X},
  url = {https://pubs.acs.org/doi/10.1021/acs.est.4c13635},
  doi = {10.1021/acs.est.4c13635},
  pdf={Wang_etal2025.pdf},
  abstract = {To provide early warning and support a rapid response to a novel virus through wastewater surveillance, it would be ideal to understand in advance which concentration and extraction methods can reliably detect and quantify any virus of concern. We compared four concentration methods (polyethylene glycol precipitation, ultrafiltration, immunomagnetic separation, and adsorption-vortex) and two extraction methods (proteinase K and phosphate-buffered saline) for quantifying eight common human respiratory viruses in wastewater samples.},
  selected = {true}
}
